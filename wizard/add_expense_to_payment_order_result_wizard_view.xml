<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_add_expense_to_payment_order_result_wizard_form" model="ir.ui.view">
        <field name="name">add.expense.to.payment.order.result.wizard.form</field>
        <field name="model">add.expense.to.payment.order.result.wizard</field>
        <field name="arch" type="xml">
            <form string="Resultado de la operación">
                <div class="alert alert-warning" role="alert">
                    <field name="summary_message" nolabel="1" readonly="1"/>
                </div>
                <footer>
                    <button string="Abrir Orden de Pago" type="object" name="action_open_order" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
